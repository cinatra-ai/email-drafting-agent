{
  "name": "@cinatra-ai/email-drafting-agent",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "files": [
    "cinatra",
    "skills"
  ],
  "description": "Generates personalized initial emails for every recipient.",
  "type": "module",
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "agent",
    "dependencies": [
      {
        "packageName": "@cinatra-ai/auditor-agent",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "exact",
          "version": "0.1.0"
        },
        "requirement": "required",
        "kind": "agent"
      },
      {
        "packageName": "@cinatra-ai/reviewer-agent",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "exact",
          "version": "0.1.0"
        },
        "requirement": "required",
        "kind": "agent"
      }
    ],
    "agentDependencies": {
      "@cinatra-ai/reviewer-agent": "^0.1.0",
      "@cinatra-ai/auditor-agent": "^0.1.1"
    },
    "fieldRenderers": [
      {
        "id": "@cinatra-ai/email-drafting-agent:output",
        "kind": "email-drafts-review",
        "priority": 80,
        "a2uiTranslator": "drafts-output"
      },
      {
        "id": "@cinatra-ai/email-drafting-agent:email-drafts-review",
        "kind": "email-drafts-review",
        "priority": 80
      },
      {
        "id": "@cinatra-ai/email-drafting-agent:follow-up-cadence",
        "kind": "follow-up-cadence",
        "priority": 90
      }
    ]
  }
}
